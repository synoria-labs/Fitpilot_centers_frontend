# --- Local session / auth token cache (NEVER commit — contiene JWTs vivos) ---
data/.session.json
data/*.session.json

# --- PowerShell redirection junk (p. ej. `pip install x>=1.2.3` crea el archivo `=1.2.3`) ---
=*

